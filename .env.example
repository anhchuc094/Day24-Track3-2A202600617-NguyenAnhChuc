# Required — chọn 1 trong 2 provider
# ──────────────────────────────────────
# Option A: OpenAI (mặc định)
OPENAI_API_KEY=sk-...

# Option B: Groq (miễn phí, nhanh hơn — khuyên dùng cho lab)
GROQ_API_KEY=gsk_...

# Provider: "openai" hoặc "groq"  (mặc định = "groq" nếu có GROQ_API_KEY)
LLM_PROVIDER=groq

# Model (tùy chọn — mặc định đã đặt sẵn theo provider)
# Groq:   llama-3.1-8b-instant | llama-3.3-70b-versatile | mixtral-8x7b-32768
# OpenAI: gpt-4o-mini | gpt-4o
LLM_MODEL=llama-3.3-70b-versatile

# Optional: HuggingFace token (chỉ dùng nếu dùng HF Inference Endpoints)
HF_TOKEN=hf_...
